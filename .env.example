# Development-only defaults. Copy to .env and replace before any cloud deployment.
POSTGRES_DB=fashion_recommendation
POSTGRES_USER=fashion
POSTGRES_PASSWORD=fashion_2404
POSTGRES_PORT=5433

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=fashion_minio_admin
MINIO_ROOT_PASSWORD=fashion_2404
MINIO_BUCKET=garments-private
MINIO_MAX_FILE_SIZE=10485760

# Docker application profile: docker compose --profile app up --build -d
BACKEND_PORT=8088
FRONTEND_PORT=8090
AUTH_REGISTRATION_ENABLED=true
SESSION_TIMEOUT=30m
SESSION_COOKIE_SECURE=false
DASHSCOPE_API_KEY=
BAILIAN_MODEL=qwen-plus
BAILIAN_VISION_ENABLED=false
BAILIAN_VISION_MODEL=qwen-vl-plus
BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
BAILIAN_CONNECT_TIMEOUT=3s
BAILIAN_READ_TIMEOUT=8s

# Optional authorized JSON trend feed. Leave empty to use clearly labeled development samples.
TREND_JSON_URL=
TREND_PLATFORM=configured-feed
TREND_CONNECT_TIMEOUT=3s
TREND_READ_TIMEOUT=5s
TREND_CACHE_TTL=15m

# Weather providers: wttr.in is primary and Open-Meteo is the fallback.
WEATHER_PRIMARY_BASE_URL=https://wttr.in
WEATHER_FALLBACK_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com
WEATHER_FALLBACK_FORECAST_BASE_URL=https://api.open-meteo.com
WEATHER_CONNECT_TIMEOUT=3s
WEATHER_READ_TIMEOUT=3s
WEATHER_CACHE_TTL=15m
WEATHER_CACHE_MAX_SIZE=500
